# OSV Engineering API Key (used for both Web Search and Web Crawling)
# Get your key at https://osv.engineering
OSV_API_KEY=your_osv_api_key_here

# Anthropic API Key (for Claude LLM classification/ranking)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Claude model to use (defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: Max search results per query (defaults to 5)
MAX_RESULTS_PER_QUERY=5

# Optional: Max pages to crawl per URL (defaults to 1)
MAX_CRAWL_PAGES=1
